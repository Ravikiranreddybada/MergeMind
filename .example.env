# Example environment configuration for the Bug‑to‑PR Autopilot

# Groq API key for language model access (LLM provider)
GROQ_API_KEY=your_groq_api_key_here

# GitHub Personal Access Token
GITHUB_TOKEN=

# GitHub App credentials
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=

# Slack App credentials
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=

# Redis and database connection strings (optional)
REDIS_URL=
DATABASE_URL=
